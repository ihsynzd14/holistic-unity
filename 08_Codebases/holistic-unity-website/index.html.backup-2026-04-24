  <style>
    /* index.html overrides */
    .section-pad { padding: 120px 0; }
    .reveal-scale { opacity: 0; transform: scale(0.9); transition: opacity 0.6s ease, transform 0.6s ease; }
    .reveal-scale.visible { opacity: 1; transform: scale(1); }

    /* ==================== HERO ==================== */
    .hero {
      min-height: 100vh;
      display: flex;
      align-items: center;
      position: relative;
      overflow: hidden;
      background: linear-gradient(160deg, var(--cream) 0%, var(--soft-pink) 40%, #E8D0D9 70%, #D4B8C5 100%);
    }
    .hero::before {
      content: '';
      position: absolute;
      top: -50%; right: -20%;
      width: 800px; height: 800px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(201, 169, 110, 0.15) 0%, transparent 70%);
      animation: float-orb 20s ease-in-out infinite;
    }
    .hero::after {
      content: '';
      position: absolute;
      bottom: -30%; left: -10%;
      width: 600px; height: 600px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(139, 34, 82, 0.08) 0%, transparent 70%);
      animation: float-orb 15s ease-in-out infinite reverse;
    }
    @keyframes float-orb {
      0%, 100% { transform: translate(0, 0) scale(1); }
      33% { transform: translate(30px, -40px) scale(1.05); }
      66% { transform: translate(-20px, 20px) scale(0.95); }
    }

    .hero .container {
      position: relative;
      z-index: 2;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 80px;
      align-items: center;
      padding-top: 100px;
    }
    .hero-content h1 {
      font-family: var(--font-display);
      font-size: 4.2rem;
      font-weight: 600;
      line-height: 1.1;
      color: var(--berry);
      letter-spacing: -0.03em;
      margin-bottom: 24px;
    }
    .hero-content h1 em {
      font-style: italic;
      color: var(--gold);
    }
    .hero-content p {
      font-size: 1.15rem;
      line-height: 1.7;
      color: var(--charcoal-light);
      margin-bottom: 40px;
      max-width: 500px;
    }
    .hero-buttons {
      display: flex;
      gap: 16px;
      flex-wrap: wrap;
    }
    .btn-primary {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: var(--berry);
      color: var(--white);
      padding: 16px 36px;
      border-radius: 50px;
      font-size: 1rem;
      font-weight: 600;
      text-decoration: none;
      transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
      box-shadow: 0 8px 30px rgba(139, 34, 82, 0.3);
      border: none;
      cursor: pointer;
      font-family: var(--font-body);
    }
    .btn-primary:hover {
      background: var(--berry-dark);
      transform: translateY(-3px);
      box-shadow: 0 12px 40px rgba(139, 34, 82, 0.4);
    }
    .btn-secondary {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: transparent;
      color: var(--berry);
      padding: 16px 36px;
      border-radius: 50px;
      font-size: 1rem;
      font-weight: 600;
      text-decoration: none;
      border: 2px solid var(--berry);
      transition: all 0.4s ease;
      cursor: pointer;
      font-family: var(--font-body);
    }
    .btn-secondary:hover {
      background: var(--berry);
      color: var(--white);
      transform: translateY(-3px);
      box-shadow: 0 8px 30px rgba(139, 34, 82, 0.25);
    }

    .hero-visual {
      position: relative;
      display: flex;
      justify-content: center;
      align-items: center;
    }
    .hero-image-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 12px;
      transform: rotate(-3deg);
      width: 100%;
      min-width: 280px;
    }
    .hero-image-grid img {
      width: 100%;
      aspect-ratio: 1;
      object-fit: cover;
      border-radius: 20px;
      box-shadow: 0 10px 40px rgba(0,0,0,0.1);
      transition: transform 0.5s ease;
    }
    .hero-image-grid img:hover {
      transform: scale(1.05) rotate(2deg);
    }
    .hero-image-grid img:nth-child(2) { transform: translateY(20px); }
    .hero-image-grid img:nth-child(2):hover { transform: translateY(20px) scale(1.05) rotate(2deg); }
    .hero-image-grid img:nth-child(5) { transform: translateY(-15px); }
    .hero-image-grid img:nth-child(5):hover { transform: translateY(-15px) scale(1.05) rotate(2deg); }

    .hero-badge {
      position: absolute;
      bottom: -20px;
      right: 30px;
      background: var(--white);
      padding: 16px 28px;
      border-radius: 16px;
      box-shadow: 0 10px 40px rgba(0,0,0,0.1);
      display: flex;
      align-items: center;
      gap: 12px;
      z-index: 3;
    }
    .hero-badge .pulse {
      width: 12px; height: 12px;
      background: #4CAF50;
      border-radius: 50%;
      animation: pulse 2s infinite;
    }
    @keyframes pulse {
      0% { box-shadow: 0 0 0 0 rgba(76, 175, 80, 0.4); }
      70% { box-shadow: 0 0 0 10px rgba(76, 175, 80, 0); }
      100% { box-shadow: 0 0 0 0 rgba(76, 175, 80, 0); }
    }
    .hero-badge span {
      font-size: 0.85rem;
      font-weight: 600;
      color: var(--charcoal);
    }

    /* ==================== STATS BAR ==================== */
    .stats-bar {
      background: var(--white);
      padding: 48px 0;
      border-top: 1px solid rgba(139, 34, 82, 0.06);
      border-bottom: 1px solid rgba(139, 34, 82, 0.06);
    }
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 40px;
      text-align: center;
      justify-items: center;
    }
    .stat-item h3 {
      font-family: var(--font-display);
      font-size: 2.8rem;
      font-weight: 700;
      color: var(--berry);
      line-height: 1;
      margin-bottom: 8px;
    }
    .stat-item p {
      font-size: 0.9rem;
      color: var(--charcoal-light);
      font-weight: 500;
    }

    /* ==================== HOW IT WORKS ==================== */
    .how-it-works {
      background: var(--cream);
    }
    .section-header {
      text-align: center;
      margin-bottom: 80px;
    }
    .section-label {
      display: inline-block;
      background: linear-gradient(135deg, var(--gold), var(--gold-light));
      background-clip: text;
      -webkit-background-clip: text;
      color: transparent;
      font-size: 0.85rem;
      font-weight: 700;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      margin-bottom: 16px;
    }
    .section-title {
      font-family: var(--font-display);
      font-size: 3.5rem;
      font-weight: 600;
      color: var(--berry);
      line-height: 1.2;
      margin-bottom: 24px;
    }
    .section-subtitle {
      font-size: 1.15rem;
      color: var(--charcoal-light);
      max-width: 600px;
      margin: 0 auto;
      line-height: 1.7;
    }

    /* ==================== HOW IT WORKS STEPS ==================== */
    .steps-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 40px;
      margin-top: 60px;
    }
    .step-card {
      background: var(--white);
      padding: 48px 40px;
      border-radius: 20px;
      text-align: left;
      border: 1px solid rgba(139, 34, 82, 0.1);
      transition: all 0.3s ease;
      position: relative;
      overflow: hidden;
    }
    .step-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0;
      width: 100%;
      height: 4px;
      background: linear-gradient(90deg, var(--berry), var(--gold));
    }
    .step-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 20px 40px rgba(139, 34, 82, 0.1);
    }
    .step-card h3 {
      font-size: 1.3rem;
      color: var(--berry);
      margin-bottom: 16px;
      font-weight: 600;
    }
    .step-card p {
      color: var(--charcoal-light);
      line-height: 1.7;
      font-size: 0.95rem;
    }
    .step-number {
      position: absolute;
      top: 20px; right: 30px;
      font-family: var(--font-display);
      font-size: 4rem;
      font-weight: 700;
      color: rgba(139, 34, 82, 0.05);
    }

    /* ==================== THERAPIES SECTION ==================== */
    .therapies {
      background: var(--white);
    }
    .therapies-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 30px;
      margin-top: 60px;
    }
    .therapy-card {
      background: var(--cream);
      border-radius: 16px;
      overflow: hidden;
      transition: all 0.3s ease;
      border: 1px solid rgba(139, 34, 82, 0.08);
    }
    .therapy-card:hover {
      transform: translateY(-8px);
      box-shadow: 0 25px 50px rgba(139, 34, 82, 0.15);
    }
    .therapy-card img {
      width: 100%;
      height: 200px;
      object-fit: cover;
    }
    .therapy-info {
      padding: 32px 24px;
    }
    .therapy-card h3 {
      font-size: 1.4rem;
      color: var(--berry);
      margin-bottom: 16px;
      font-weight: 600;
    }
    .therapy-card p {
      color: var(--charcoal-light);
      line-height: 1.7;
      font-size: 0.95rem;
    }
    .therapy-card a {
      display: inline-block;
      margin-top: 20px;
      color: var(--berry);
      text-decoration: none;
      font-weight: 600;
      font-size: 0.9rem;
      transition: all 0.3s;
    }
    .therapy-card a:hover {
      color: var(--gold);
    }

    /* ==================== THERAPISTS SECTION ==================== */
    .therapists {
      background: var(--cream);
    }
    .benefits-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 40px;
      margin-top: 60px;
    }
    .benefit-card {
      background: var(--white);
      padding: 40px;
      border-radius: 16px;
      border-left: 4px solid var(--gold);
    }
    .benefit-card h3 {
      font-size: 1.3rem;
      color: var(--berry);
      margin-bottom: 16px;
      font-weight: 600;
    }
    .benefit-card p {
      color: var(--charcoal-light);
      line-height: 1.7;
      font-size: 0.95rem;
    }

    .therapist-cta-section {
      background: linear-gradient(135deg, rgba(139, 34, 82, 0.08), rgba(201, 169, 110, 0.08));
      padding: 60px 48px;
      border-radius: 20px;
      text-align: center;
      margin-top: 60px;
    }
    .therapist-cta-section h3 {
      font-size: 2rem;
      color: var(--berry);
      margin-bottom: 16px;
      font-weight: 600;
    }
    .therapist-cta-section p {
      color: var(--charcoal-light);
      margin-bottom: 24px;
      font-size: 1rem;
      line-height: 1.7;
    }

    /* ==================== QUOTE SECTION ==================== */
    .quote-section {
      background: linear-gradient(135deg, var(--berry) 0%, var(--berry-dark) 100%);
      padding: 80px 40px;
      text-align: center;
      color: var(--white);
    }
    .quote-text {
      font-family: var(--font-display);
      font-size: 2.2rem;
      font-weight: 500;
      line-height: 1.6;
      margin-bottom: 24px;
      font-style: italic;
    }
    .quote-author {
      font-size: 0.95rem;
      opacity: 0.9;
      font-weight: 500;
    }

    /* ==================== CONTACT SECTION ==================== */
    .contact {
      background: var(--white);
    }
    .contact-wrapper {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 80px;
      align-items: start;
      margin-top: 60px;
    }
    .contact-form-wrapper {
      position: relative;
    }
    .contact-form {
      display: flex;
      flex-direction: column;
      gap: 24px;
    }
    .form-group {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }
    .form-group label {
      font-weight: 600;
      color: var(--berry);
      font-size: 0.9rem;
    }
    .form-group input,
    .form-group textarea,
    .form-group select {
      padding: 14px 16px;
      border: 1px solid rgba(139, 34, 82, 0.2);
      border-radius: 12px;
      font-family: var(--font-body);
      font-size: 0.95rem;
      color: var(--charcoal);
      transition: all 0.3s;
    }
    .form-group input:focus,
    .form-group textarea:focus,
    .form-group select:focus {
      outline: none;
      border-color: var(--berry);
      box-shadow: 0 0 0 3px rgba(139, 34, 82, 0.1);
    }
    .form-group textarea {
      resize: vertical;
      min-height: 120px;
    }
    .form-submit {
      background: var(--berry);
      color: var(--white);
      padding: 14px 36px;
      border: none;
      border-radius: 50px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.3s;
      font-size: 1rem;
      font-family: var(--font-body);
    }
    .form-submit:hover {
      background: var(--berry-dark);
      transform: translateY(-2px);
      box-shadow: 0 8px 20px rgba(139, 34, 82, 0.3);
    }
    .form-submit:disabled {
      opacity: 0.6;
      cursor: not-allowed;
    }
    .form-success {
      position: absolute;
      top: 0; left: 0;
      right: 0; bottom: 0;
      background: var(--white);
      border-radius: 12px;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 16px;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.3s;
    }
    .form-success.show {
      opacity: 1;
      pointer-events: auto;
    }
    .form-success h4 {
      font-size: 1.3rem;
      color: var(--berry);
    }
    .form-success p {
      color: var(--charcoal-light);
      text-align: center;
    }

